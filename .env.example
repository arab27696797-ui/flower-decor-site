# ==============================================================================
# flower-decor-site — environment variables template
# Copy this file to .env.local for local development.
# Never commit .env.local or any real secrets to the repository.
# ==============================================================================


# ------------------------------------------------------------------------------
# Database (Prisma)
# ------------------------------------------------------------------------------

# Full connection string for your PostgreSQL database.
# For Railway: copy from the Railway Postgres plugin → Variables tab.
# For local development: use a local Postgres instance or Railway proxy.
DATABASE_URL="postgresql://user:password@localhost:5432/flower_decor_db?schema=public"


# ------------------------------------------------------------------------------
# Admin panel authentication
# ------------------------------------------------------------------------------

# Secret used to sign and verify admin session tokens / JWT.
# Generate a strong random string: openssl rand -hex 32
ADMIN_SECRET="replace-with-a-strong-random-secret-at-least-32-chars"

# Admin login credentials (used by the login form in /admin).
# Change both values before deploying to production.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="replace-with-a-strong-password"


# ------------------------------------------------------------------------------
# Telegram lead notifications (lib/telegram.ts)
# ------------------------------------------------------------------------------

# Bot token from @BotFather — format: 123456789:ABCDEFabcdef...
# Steps: open Telegram → @BotFather → /newbot → copy the token here.
TELEGRAM_BOT_TOKEN="123456789:ABCDEFabcdefGHIJKLMNOPQRSTUVWXYZ"

# Chat ID of the staff group or personal chat that receives lead notifications.
# To find your chat ID:
#   1. Add @userinfobot to the target chat.
#   2. It will reply with the chat ID (negative number for groups, e.g. -100123456789).
# For a personal chat: send any message to your bot, then call:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID="-100123456789"


# ------------------------------------------------------------------------------
# Public site / SEO
# ------------------------------------------------------------------------------

# Canonical base URL of the deployed site — used for OG tags and sitemaps.
# No trailing slash. Use the actual production domain in production.
NEXT_PUBLIC_SITE_URL="https://your-domain.ru"

# Site display name — used in metadata titles and JSON-LD schema.
NEXT_PUBLIC_SITE_NAME="Флоральный декор Москва"

# Primary contact phone number — displayed in the navbar, contacts section,
# and injected into JSON-LD LocalBusiness schema.
NEXT_PUBLIC_PHONE="+7 (999) 000-00-00"

# WhatsApp link (include country code, no + sign, no spaces).
NEXT_PUBLIC_WHATSAPP_NUMBER="79990000000"

# Telegram username for the contact button (without @).
NEXT_PUBLIC_TELEGRAM_USERNAME="your_telegram_username"

# Instagram profile URL.
NEXT_PUBLIC_INSTAGRAM_URL="https://instagram.com/your_profile"


# ------------------------------------------------------------------------------
# Next.js runtime
# ------------------------------------------------------------------------------

# Set to 'production' on deployed environments. Next.js sets this automatically
# when you run `next build && next start`, but explicit is better on some hosts.
NODE_ENV="development"
